---
interface Props {
  eyebrow?: string;
  title?: string;
  lede?: string;
  id?: string;
  narrow?: boolean;
  class?: string;
}
const { eyebrow, title, lede, id, narrow = false, class: klass = "" } = Astro.props;
const wrapper = narrow ? "container-narrow" : "container-wide";
---
<section id={id} class={`py-16 sm:py-20 ${klass}`}>
  <div class={wrapper}>
    {(eyebrow || title || lede) && (
      <div class="mb-10 max-w-3xl">
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        {title && <h2 class="mt-2 text-3xl font-bold text-umblue-900 sm:text-4xl">{title}</h2>}
        {lede && <p class="mt-4 text-lg text-slate-700">{lede}</p>}
      </div>
    )}
    <slot />
  </div>
</section>
