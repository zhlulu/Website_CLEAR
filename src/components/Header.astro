---
const links = [
  { href: "/science", label: "Science" },
  { href: "/tools", label: "Forecasts" },
  { href: "/team", label: "Team" },
  { href: "/publications", label: "Publications" },
  { href: "/news", label: "News" },
  { href: "/contact", label: "Contact" },
];
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="sticky top-0 z-40 border-b border-slate-200/70 bg-white/85 backdrop-blur">
  <div class="container-wide flex h-16 items-center justify-between gap-6">
    <a href="/" class="flex items-center" aria-label="CLEAR Center home">
      <img src="/clear.png" alt="CLEAR — Center for All-Clear SEP Forecast" class="h-10 w-auto" />
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
      {links.map((l) => {
        const active = path === l.href;
        return (
          <a
            href={l.href}
            class={`rounded-md px-3 py-2 text-sm font-medium ${
              active
                ? "text-umblue-800 underline decoration-maize-500 decoration-2 underline-offset-4"
                : "text-slate-700 hover:text-umblue-800"
            }`}
          >
            {l.label}
          </a>
        );
      })}
    </nav>

    <details class="md:hidden">
      <summary class="cursor-pointer list-none rounded-md border border-slate-200 p-2 text-slate-700">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </summary>
      <div class="absolute inset-x-0 top-16 border-b border-slate-200 bg-white p-4 shadow-sm">
        <div class="grid gap-1">
          {links.map((l) => (
            <a href={l.href} class="rounded px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">{l.label}</a>
          ))}
        </div>
      </div>
    </details>
  </div>
</header>
