const base = import.meta.env.BASE_URL;
const u = (p: string) => `${base}${p.replace(/^\//, "")}`;
---

<BaseLayout title="The Team — CLEAR Center" description="The CLEAR Center team: executive committee, advisory board, operational collaborators, members, and graduate students.">
  <Section
    eyebrow="The Team"
    title="A multi-institution team built for an interdisciplinary problem"
    lede="CLEAR unites theoreticians, observers, computational model developers, statisticians, and machine-learning experts across universities, NASA centers, and operational users."
  />

  <!-- Executive Committee -->
  <section class="pb-10">
    <div class="container-wide">
      <h2 class="text-2xl font-bold text-umblue-900 sm:text-3xl">Executive Committee</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {executive.map((p) => (
          <article class="flex gap-5 rounded-xl border border-slate-200 bg-white p-5">
            <img src={u(p.img)} alt={p.name} class="h-24 w-24 shrink-0 rounded-full object-cover ring-2 ring-maize-500/40 bg-slate-300" loading="lazy" />
            <div>
              <h3 class="text-base font-semibold text-umblue-900">
                {p.title ? `${p.title} ` : ""}{p.name}
              </h3>
              {p.role && <p class="text-xs font-medium text-umblue-800">{p.role}</p>}
              {p.affiliation && <p class="mt-1 text-sm text-slate-500">{p.affiliation}</p>}
              {p.url && (
                <a class="mt-2 inline-block text-sm font-semibold text-umblue-800 hover:text-umblue-700" href={p.url} target="_blank" rel="noopener noreferrer">
                  Website →
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Team Members -->
  <section class="bg-slate-50 py-16 sm:py-20">
    <div class="container-wide">
      <h2 class="text-2xl font-bold text-umblue-900 sm:text-3xl">Team Members</h2>

      <div class="mt-10 space-y-12">
        {memberGroups.map((g) => (
          <div>
            <h3 class="border-l-4 border-maize-500 pl-3 text-sm font-semibold uppercase tracking-wider text-umblue-800">
              {g.label}
            </h3>
            <div class="mt-5 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {g.people.map((p) => (
                <article class="flex gap-5 rounded-xl border border-slate-200 bg-white p-5">
                  <img src={u(p.img)} alt={p.name} class="h-24 w-24 shrink-0 rounded-full object-cover" loading="lazy" />
                  <div>
                    <h4 class="text-base font-semibold text-umblue-900">{p.name}</h4>
                    {p.role && <p class="text-xs font-medium text-umblue-800">{p.role}</p>}
                    {p.affiliation && <p class="mt-1 text-sm text-slate-500">{p.affiliation}</p>}
                    {p.url && (
                      <a class="mt-2 inline-block text-sm font-semibold text-umblue-800 hover:text-umblue-700" href={p.url} target="_blank" rel="noopener noreferrer">
                        Website →
                      </a>
                    )}
                  </div>
                </article>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- External Advisory Board -->
  <section class="bg-slate-50 py-16 sm:py-20">
    <div class="container-wide">
      <h2 class="text-2xl font-bold text-umblue-900 sm:text-3xl">External Advisory Board</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {advisoryBoard.map((p) => (
          <article class="flex gap-5 rounded-xl border border-slate-200 bg-white p-5">
            <img src={u(p.img)} alt={p.name} class="h-24 w-24 shrink-0 rounded-full object-cover" loading="lazy" />
            <div>
              <h3 class="text-base font-semibold text-umblue-900">
                {p.title ? `${p.title} ` : ""}{p.name}
              </h3>
              {p.affiliation && <p class="mt-1 text-sm text-slate-500">{p.affiliation}</p>}
              {p.url && (
                <a class="mt-2 inline-block text-sm font-semibold text-umblue-800 hover:text-umblue-700" href={p.url} target="_blank" rel="noopener noreferrer">
                  Website →
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Operational Collaborators -->
  <section class="py-16 sm:py-20">
    <div class="container-wide">
      <h2 class="text-2xl font-bold text-umblue-900 sm:text-3xl">Operational Collaborators</h2>

      <div class="mt-10 space-y-12">
        {operationalGroups.map((g) => (
          <div>
            <h3 class="border-l-4 border-maize-500 pl-3 text-sm font-semibold uppercase tracking-wider text-umblue-800">
              {g.label}
            </h3>
            <div class="mt-5 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {g.people.map((p) => (
                <article class="flex gap-5 rounded-xl border border-slate-200 bg-white p-5">
                  <img src={u(p.img)} alt={p.name} class="h-24 w-24 shrink-0 rounded-full object-cover" loading="lazy" />
                  <div>
                    <h4 class="text-base font-semibold text-umblue-900">{p.name}</h4>
                    {p.role && <p class="text-xs font-medium text-umblue-800">{p.role}</p>}
                    {p.affiliation && <p class="mt-1 text-sm text-slate-500">{p.affiliation}</p>}
                    {p.url && (
                      <a class="mt-2 inline-block text-sm font-semibold text-umblue-800 hover:text-umblue-700" href={p.url} target="_blank" rel="noopener noreferrer">
                        Website →
                      </a>
                    )}
                  </div>
                </article>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
