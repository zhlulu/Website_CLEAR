---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";

type Tool = {
  name: string;
  body: string;
  status?: "Available" | "Coming Soon";
  url?: string;
};

type Group = {
  id: string;
  label: string;
  blurb: string;
  accent: "maize" | "umblue-dark" | "umblue-light";
  tools: Tool[];
};

const groups: Group[] = [
  {
    id: "empirical",
    label: "Empirical models",
    blurb: "Fast, interpretable models relating eruptive-event observables directly to SEP properties.",
    accent: "maize",
    tools: [
      {
        name: "SEPSTER",
        body: "SEP prediction derived from STEReo observations — the original empirical model relating peak proton intensity to CME speed and the observer's magnetic connectivity.",
        status: "Available",
        url: "https://ccmc.gsfc.nasa.gov/models/SEPSTER~v2/",
      },
      {
        name: "SEPSTER (2D)",
        body: "Two-dimensional extension of SEPSTER that relates peak proton intensities and spectra to the speed and direction of the associated CME relative to the observer's magnetic footpoint — providing longitudinally-resolved empirical predictions.",
        status: "Available",
        url: "https://ccmc.gsfc.nasa.gov/models/SEPSTER2D~v1/",
      },
      {
        name: "SEPSTER-EPAM",
        body: "Empirical SEP prediction driven by in-situ particle measurements from the EPAM (Electron, Proton, and Alpha Monitor) instrument, complementing the CME-driven SEPSTER family with a particle-data-based signal.",
        status: "Coming Soon",
      },
    ],
  },
  {
    id: "ml",
    label: "AI / ML models",
    blurb: "Machine-learning models trained on decades of SEP, CME, and flare data — extending forecasts into the pre-eruption phase.",
    accent: "umblue-light",
    tools: [
      {
        name: "SEPNET",
        body: "Machine-learning SEP forecast model. Run the live SEPNET app on the Michigan Space Weather Machine-Learning Portal.",
        status: "Available",
        url: "https://mlsw.engin.umich.edu/apps/runSEP",
      },
    ],
  },
  {
    id: "physics",
    label: "Physics-based models",
    blurb: "Global simulations from the solar corona through the inner heliosphere, providing the background state and magnetic connectivity for every SEP forecast.",
    accent: "umblue-dark",
    tools: [
      {
        name: "SOFIE",
        body: "Physics-based SEP forecasting tool integrating the CLEAR Center's full modeling pipeline — from CME initiation through shock-driven particle acceleration and interplanetary transport.",
        status: "Coming Soon",
      },
      {
        name: "Daily Solar Wind",
        body: "Daily background solar-wind solution driven by GONG magnetograms through the Alfvén Wave Solar-atmosphere Model (AWSoM-R).",
        status: "Available",
        url: "https://solarwind.engin.umich.edu/",
      },
      {
        name: "Real-time Solar Wind",
        body: "Continuously updated background solar-wind module, refreshed as new near-real-time magnetograms arrive — the substrate that all other CLEAR physics modules plug into.",
        status: "Available",
        url: "https://solarwind.engin.umich.edu/pipeline/",
      },
      {
        name: "Magnetic Connectivity",
        body: "Magnetic connectivity maps between the solar surface and any point in the inner/middle heliosphere, built on the Stream-Aligned MHD (SA-MHD) method — critical input for every SEP forecast.",
        status: "Available",
        url: "http://fieldlines.engin.umich.edu/",
      },
    ],
  },
];

const accentStyles = {
  maize: "bg-maize-100 text-umblue-900",
  "umblue-dark": "bg-umblue-800 text-maize-300",
  "umblue-light": "bg-umblue-100 text-umblue-900",
};

const statusStyles = {
  Available: "bg-maize-100 text-umblue-900",
  "Coming Soon": "bg-slate-100 text-slate-600",
};

const gaps = [
  {
    title: "Pre-eruption probabilistic forecasts",
    body: "Predict the likelihood of an SEP event before the eruption occurs, from active-region magnetic-field and coronal observations.",
  },
  {
    title: "Onset-time prediction",
    body: "Forecast when energetic particles will arrive — currently limited by the very short lag between solar eruption and particle arrival.",
  },
  {
    title: "Time–intensity profiles",
    body: "Predict the full rise–peak–decay profile of an event, not just the peak flux.",
  },
  {
    title: "Spectral characteristics",
    body: "Forecast the energy spectrum of an event, not just a single integrated intensity.",
  },
  {
    title: "All-clear windows",
    body: "Issue high-confidence all-clear forecasts so operations can schedule EVAs and launches around SEP events.",
  },
];
---

<BaseLayout title="Tools — CLEAR Center" description="CLEAR Center SEP forecasting tools, grouped by empirical, AI/ML, and physics-based models.">
  <Section
    eyebrow="Tools"
    title="CLEAR Center forecasting tools"
    lede="Operational products and prototypes delivered by the CLEAR Center, organized by modeling paradigm. Links to live instances appear on each card as the tools come online."
  >
    <!-- Quick-jump nav -->
    <nav aria-label="Tool groups" class="flex flex-wrap gap-2 pb-4">
      {groups.map((g) => (
        <a
          href={`#${g.id}`}
          class={`rounded-full px-4 py-1.5 text-xs font-semibold uppercase tracking-wider ${accentStyles[g.accent]}`}
        >
          {g.label}
        </a>
      ))}
    </nav>

    <div class="space-y-16">
      {groups.map((g) => (
        <section id={g.id} class="scroll-mt-24">
          <div class="flex items-center gap-3">
            <span class={`rounded-full px-3 py-1 text-[10px] font-semibold uppercase tracking-wider ${accentStyles[g.accent]}`}>
              {g.label}
            </span>
          </div>
          <h2 class="mt-3 text-2xl font-bold text-umblue-900 sm:text-3xl">{g.label}</h2>
          <p class="mt-2 max-w-3xl text-slate-600">{g.blurb}</p>

          <div class="mt-6 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
            {g.tools.map((t) => {
              const isAvailable = t.status === "Available";
              const base =
                "flex flex-col rounded-xl border bg-white p-6 " +
                (isAvailable ? "border-slate-200" : "border-slate-200 opacity-80");
              return (
                <article class={base}>
                  <div class="flex items-start justify-between gap-3">
                    <h3 class="text-lg font-semibold text-umblue-900">{t.name}</h3>
                    {t.status && (
                      <span class={`shrink-0 rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider ${statusStyles[t.status]}`}>
                        {t.status}
                      </span>
                    )}
                  </div>
                  <p class="mt-3 grow text-base leading-relaxed text-slate-600">{t.body}</p>
                  {t.url && (
                    <a
                      class="mt-5 inline-flex w-fit items-center gap-2 rounded-md bg-umblue-800 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-umblue-900"
                      href={t.url}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      Launch tool →
                    </a>
                  )}
                </article>
              );
            })}
          </div>
        </section>
      ))}
    </div>
  </Section>

  <!-- Forecasting gaps -->
  <section class="bg-umblue-900 py-16 text-white sm:py-20">
    <div class="container-wide">
      <div class="max-w-3xl">
        <p class="eyebrow text-maize-400">Forecasting gaps</p>
        <h2 class="mt-2 text-3xl font-bold sm:text-4xl">
          Five forecast products still missing from operations
        </h2>
        <p class="mt-4 text-lg text-slate-300">
          NASA's Space Weather Science and Measurement Gap Analysis identifies
          five concrete SEP forecast products that current operations cannot
          reliably deliver. CLEAR's tools advance each of them.
        </p>
      </div>
      <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {gaps.map((g, i) => (
          <article class="flex gap-4 rounded-xl bg-white/5 p-6 ring-1 ring-white/10 backdrop-blur">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-maize-500 text-sm font-semibold text-umblue-900">
              {i + 1}
            </div>
            <div>
              <h3 class="text-base font-semibold text-white">{g.title}</h3>
              <p class="mt-1 text-base leading-relaxed text-slate-300">{g.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-16 sm:py-20">
    <div class="container-wide">
      <p class="eyebrow">R2O &rarr; O2R</p>
      <h2 class="mt-2 text-3xl font-bold text-umblue-900 sm:text-4xl">
        Research to operations, operations to research.
      </h2>
      <p class="mt-4 text-slate-600">
        CLEAR tools are delivered to the
        <a class="font-semibold text-umblue-800 hover:text-umblue-700" href="https://ccmc.gsfc.nasa.gov/" target="_blank" rel="noopener noreferrer">Community Coordinated Modeling Center (CCMC)</a>
        for community access, and feedback from operations feeds directly back
        into the Center's research program. For collaboration inquiries,
        <a class="font-semibold text-umblue-800 hover:text-umblue-700" href={`${import.meta.env.BASE_URL}contact`}>contact the center</a>.
      </p>
    </div>
  </section>
</BaseLayout>
