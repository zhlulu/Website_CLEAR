function pubLink(p: Pub): string | undefined {
  if (p.url) return p.url;
  if (p.doi) return `https://doi.org/${p.doi}`;
  if (p.arxiv) return `https://arxiv.org/abs/${p.arxiv}`;
  return undefined;
}

const totalCount = pubYears.reduce((sum, y) => sum + y.items.length, 0);
---

<BaseLayout title="Publications — CLEAR Center" description="Peer-reviewed publications from the CLEAR Center for All-Clear SEP Forecast.">
  <Section
    eyebrow="Publications"
    title="CLEAR Center publications"
    lede={`Peer-reviewed papers and preprints produced by the CLEAR Center (${totalCount} entries). Updated as papers are accepted; click any entry to open its DOI or preprint.`}
  >
    <div class="space-y-16">
      {pubYears.map((yr) => (
        <section id={`y${yr.year}`}>
          <div class="flex items-baseline gap-3 border-b border-slate-200 pb-3">
            <h2 class="text-2xl font-bold text-umblue-900 sm:text-3xl">{yr.label}</h2>
            <span class="text-sm text-slate-500">{yr.items.length} {yr.items.length === 1 ? "entry" : "entries"}</span>
          </div>
          <ol class="mt-6 space-y-5">
            {yr.items.map((p, i) => {
              const href = pubLink(p);
              return (
                <li class="flex gap-4 border-l-2 border-maize-500 pl-5">
                  <span class="mt-0.5 shrink-0 font-mono text-sm font-semibold text-maize-600">{String(i + 1).padStart(2, "0")}</span>
                  <div class="min-w-0 flex-1">
                    <p class="text-sm text-slate-600">{p.authors} <span class="text-slate-500">({p.year})</span></p>
                    <h3 class="mt-1 text-base font-semibold leading-snug text-umblue-900">
                      {href ? (
                        <a class="hover:text-umblue-700 hover:underline decoration-maize-500 underline-offset-4" href={href} target="_blank" rel="noopener noreferrer">
                          {p.title}
                        </a>
                      ) : (
                        p.title
                      )}
                    </h3>
                    <p class="mt-1 text-sm italic text-slate-600">
                      {p.venue}
                      {p.status && <span class="not-italic"> — <span class="rounded bg-slate-100 px-1.5 py-0.5 text-xs font-medium uppercase tracking-wider text-slate-600">{p.status}</span></span>}
                    </p>
                    {href && (
                      <a class="mt-1 inline-flex items-center gap-1 text-xs font-semibold text-umblue-800 hover:text-umblue-700" href={href} target="_blank" rel="noopener noreferrer">
                        {p.doi ? `DOI: ${p.doi}` : p.arxiv ? `arXiv: ${p.arxiv}` : "Link"} →
                      </a>
                    )}
                  </div>
                </li>
              );
            })}
          </ol>
        </section>
      ))}
    </div>

    <!-- Foundational references -->
    <section class="mt-20 border-t border-slate-200 pt-12">
      <h2 class="text-2xl font-bold text-umblue-900 sm:text-3xl">Foundational references</h2>
      <p class="mt-2 max-w-3xl text-sm text-slate-600">
        Earlier papers that the CLEAR framework builds on — the modeling substrate and empirical methods that the Center extends and integrates.
      </p>
      <ul class="mt-6 space-y-4 text-sm text-slate-700">
        <li class="border-l-2 border-maize-500 pl-4">
          Gombosi, T. I. et al. — <em>Space Weather Modeling Framework</em>. The modeling substrate that CLEAR builds on.
        </li>
        <li class="border-l-2 border-maize-500 pl-4">
          Sokolov, I. V. et al. — <em>Alfvén Wave Solar-atmosphere Model (AWSoM / AWSoM-R)</em>. Real-time background solar wind.
        </li>
        <li class="border-l-2 border-maize-500 pl-4">
          Borovikov, D. et al.; Jin, M. et al. — <em>EEGGL</em>. Magnetically-driven CME initiation.
        </li>
        <li class="border-l-2 border-maize-500 pl-4">
          Richardson, I. G. et al. — <em>SEPSTER / SEPSTER2D</em>. Empirical SEP prediction from STEREO observations.
        </li>
        <li class="border-l-2 border-maize-500 pl-4">
          Posner, A. — <em>REleASE</em>. Electron-onset precursor for proton events.
        </li>
        <li class="border-l-2 border-maize-500 pl-4">
          Sokolov, I. V. et al. — <em>Stream-Aligned MHD</em>. Magnetic connectivity without spurious V-shaped field lines.
        </li>
      </ul>
    </section>

    <p class="mt-16 text-sm text-slate-500">
      Missing a paper? <a class="font-semibold text-umblue-800 hover:text-umblue-700" href={`${import.meta.env.BASE_URL}contact`}>Contact the center</a> and we'll add it.
    </p>
  </Section>
</BaseLayout>
